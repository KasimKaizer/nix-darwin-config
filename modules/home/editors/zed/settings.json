// Zed settings — managed by nix-darwin (modules/home/editors/zed/settings.json).
//
// This is the PERMANENT baseline. On every `nixswitch` it is copied to
// ~/.config/zed/settings.json (a normal, writable file) with the @...@
// placeholders below filled in from the sops vault. Edit ~/.config/zed freely
// to experiment — those changes are ephemeral and get reset on the next switch.
// To make something permanent, edit THIS file and rebuild.
//
// The @...@ tokens are substituted at activation time from secrets/secrets.yaml.
// Never paste real secrets (API keys, usernames, hostnames) here.
//
// Docs: https://zed.dev/docs/configuring-zed
{
  // ============================================================================
  // AI: MCP context servers, agent servers, agent panel, edit predictions
  // ============================================================================
  "context_servers": {
    "mcp-server-exa-search": {
      "enabled": true,
      "remote": false,
      "settings": {
        "exa_api_key": "@ZED_EXA_API_KEY@",
      },
    },
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": "@ZED_CONTEXT7_API_KEY@",
      },
    },
    "arch-ops-server": {
      "enabled": true,
      "remote": false,
      "settings": {},
    },
    "mcp-server-github": {
      "enabled": true,
      "remote": false,
      "settings": {
        "github_personal_access_token": "@ZED_GITHUB_PAT@",
      },
    },
    "mcp-server-sequential-thinking": {
      "enabled": true,
      "remote": false,
      "settings": {},
    },
  },
  // ============================================================================
  // External Agents (ACP registry)
  // ============================================================================
  // Installed via `zed: acp registry` (or Agent Settings → Add Agent → Install
  // from Registry). These entries persist the install across `nixswitch` and set
  // per-session defaults. Auth and billing stay with each agent — Cursor login for
  // Cursor, `copilot` / GitHub sign-in for Copilot — not Zed's LLM providers.
  // Zed MCP servers in `context_servers` above are forwarded to external threads.
  //
  // Registry IDs: cursor, github-copilot-cli
  // Docs: https://zed.dev/docs/ai/external-agents
  "agent_servers": {
    "cursor": {
      "type": "registry",
      "default_mode": "agent",
    },
    "github-copilot-cli": {
      "type": "registry",
      "default_config_options": {
        "reasoning_effort": "high",
      },
    },
  },
  "agent": {
    "dock": "right",
    "default_profile": "write",
    "model_parameters": [],
    "default_model": {
      "provider": "openai-subscribed",
      "model": "gpt-5.6-sol",
      "effort": "max",
      "enable_thinking": true,
    },
    "tool_permissions": {
      "default": "allow",
      "tools": {
        "edit_file": {
          "default": "allow",
          "always_allow": [
            {
              "pattern": "^rotational-cipher/\\.zed/",
            },
          ],
        },
        "terminal": {
          "default": "allow",
        },
      },
    },
  },
  "disable_ai": false,
  "edit_predictions": {
    "mode": "subtle",
    "provider": "copilot",
    "allow_data_collection": "no",
    "copilot": {
      "enable_next_edit_suggestions": true,
    },
    // Kept for quick provider switching; inert while provider is "copilot".
    "ollama": {
      "model": "qwen2.5-coder:7b-base",
    },
    "open_ai_compatible_api": {
      "prompt_format": "infer",
    },
  },

  // ============================================================================
  // Remote development
  // ============================================================================
  "cli_default_open_behavior": "new_window",
  "ssh_connections": [
    {
      "host": "box",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/@ZED_SSH_BOX_USER@/scripts/usenet_uploads/mob_to_usenet",
          ],
        },
      ],
    },
  ],

  // ============================================================================
  // Appearance: theme, fonts, cursor, gutter/scroll cosmetics
  // ============================================================================
  "theme": "One Dark Pro",
  "icon_theme": "Material Icon Theme",
  "base_keymap": "JetBrains",
  "experimental.theme_overrides": {
    "syntax": {
      "comment": { "font_style": "italic" },
      "keyword": { "font_style": "italic" },
    },
  },
  "title_bar": { "show_sign_in": false, "show_user_picture": false },
  "ui_font_size": 15.0,
  "buffer_font_size": 15.0,
  "buffer_font_weight": 400.0,
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "buffer_font_features": {
    "liga": true,
  },
  "cursor_blink": false,
  "relative_line_numbers": "disabled",
  "vertical_scroll_margin": 0,
  "scroll_beyond_last_line": "off",
  "colorize_brackets": true,
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
    "active_line_width": 2,
  },
  "centered_layout": {
    "left_padding": 0.15,
    "right_padding": 0.15,
  },

  // ============================================================================
  // Layout: tab bar, toolbar, scrollbar, minimap, which-key
  // ============================================================================
  "tab_bar": {
    "show": false,
  },
  "toolbar": {
    "code_actions": true,
    "breadcrumbs": true,
    "quick_actions": true,
    "agent_review": true,
  },
  "scrollbar": {
    "show": "auto",
    "git_diff": true,
  },
  "minimap": {
    "show": "never",
  },
  "which_key": {
    "enabled": true,
    "delay_ms": 0,
  },

  // ============================================================================
  // Editor behavior
  // ============================================================================
  "auto_indent": "syntax_aware",
  "hard_tabs": false,
  "tab_size": 2,
  "preferred_line_length": 80,
  "soft_wrap": "editor_width",
  "use_autoclose": true,
  "use_auto_surround": true,
  "jsx_tag_auto_close": {
    "enabled": true,
  },
  "semantic_tokens": "combined",
  "autosave": "on_focus_change",
  "search": {
    "center_on_match": true,
  },
  "completion_menu_scrollbar": "auto",

  // ============================================================================
  // Assists: inlay hints, signature help, diagnostics
  // ============================================================================
  "inlay_hints": {
    "enabled": true,
  },
  // auto_signature_help implies show_signature_help_after_edits, so the latter
  // is intentionally omitted.
  "auto_signature_help": true,
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },

  // ============================================================================
  // Vim / Helix mode
  // ============================================================================
  "helix_mode": true,
  "vim": {
    "use_smartcase_find": true,
    "highlight_on_yank_duration": 200,
  },

  // ============================================================================
  // Panels (docks)
  // ============================================================================
  "git_panel": {
    "tree_view": true,
    "dock": "right",
    "button": true,
  },
  "project_panel": {
    "button": true,
    "dock": "right",
    "git_status": true,
    "default_width": 300,
  },
  "outline_panel": {
    "dock": "right",
    "button": false,
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "notification_panel": {
    "dock": "left",
    "button": false,
  },

  // ============================================================================
  // Git
  // ============================================================================
  "git": {
    "inline_blame": {
      "enabled": true,
    },
  },

  // ============================================================================
  // Formatting (global) — languages override below
  // ============================================================================
  // "auto" = Prettier where applicable (JS/TS/CSS/HTML/JSON/Markdown/YAML...),
  // otherwise the language server. Non-prettier languages (Go, TOML, etc.) need
  // no per-language formatter override thanks to this.
  "formatter": "auto",
  "format_on_save": "on",

  // ============================================================================
  // Extensions (auto-installed on startup; built-ins like Go/Bash/Markdown/YAML
  // need no extension).
  // ============================================================================
  "auto_install_extensions": {
    // MCP / context servers
    "arch-mcp": true,
    "mcp-server-context7": true,
    "mcp-server-exa-search": true,
    "mcp-server-github": true,
    "mcp-server-sequential-thinking": true,
    // Languages / grammars
    "dockerfile": true,
    "git-firefly": true,
    "html": true,
    "jsonnet": true,
    "nix": true,
    "php": true,
    "powershell": true,
    "toml": true,
    // Language servers
    "codebook": true,
    "marksman": true,
    "pyrefly": true,
    "tsgo": true,
    // Snippets
    "html-snippets": true,
    // Themes / icons
    "jetbrains-themes": true,
    "material-icon-theme": true,
    "one-dark-pro": true,
  },

  // ============================================================================
  // Language servers
  // ============================================================================
  "lsp": {
    // Go — gopls is auto-downloaded by Zed; these tune its behavior.
    "gopls": {
      "initialization_options": {
        "gofumpt": true,
        "staticcheck": true,
        "usePlaceholders": true,
        "analyses": {
          "unusedparams": true,
          "unusedwrite": true,
          "nilness": true,
          "shadow": true,
          "useany": true,
        },
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true,
        },
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "experimental": {
          "classRegex": ["\\bclass:\\s*['\"]([^'\"]*)['\"]"],
        },
      },
    },
    "eslint": {
      "settings": {
        "codeActionOnSave": {
          "rules": ["import/order"],
        },
      },
    },
    // Prettier handles formatting via global "formatter": "auto".
    "json-language-server": {
      "initialization_options": {
        "provideFormatter": false,
      },
      "settings": {
        "json": {
          "validate": {
            "enable": true,
          },
          "format": {
            "enable": false,
          },
        },
      },
    },
  },

  // ============================================================================
  // Per-language overrides
  // ============================================================================
  "languages": {
    "Go": {
      "tab_size": 4,
      "hard_tabs": true,
      // gopls (via global "auto" formatter) does gofmt/gofumpt; organize imports
      // on save via code action.
      "code_actions_on_format": {
        "source.organizeImports": true,
      },
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": true,
        "show_other_hints": true,
        "show_type_hints": true,
      },
    },
    "Nix": {
      "tab_size": 2,
      "language_servers": ["nixd", "!nil"],
      "formatter": {
        "external": {
          "command": "nixfmt",
          "arguments": ["-"],
        },
      },
    },
    "Shell Script": {
      "tab_size": 2,
      "language_servers": ["bash-language-server", "..."],
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": ["-i", "2", "-ci", "-bn", "-filename", "{buffer_path}"],
        },
      },
    },
    "PowerShell": {
      "tab_size": 4,
    },
    "Markdown": {
      "language_servers": ["marksman"],
      "soft_wrap": "editor_width",
      // Preserve trailing double-spaces (Markdown hard line breaks).
      "remove_trailing_whitespace_on_save": false,
    },
    "TOML": {
      "tab_size": 2,
    },
    "Dockerfile": {
      "tab_size": 4,
    },
    // TypeScript / JavaScript share the same config (Zed has no way to merge
    // language blocks, so both are spelled out).
    "TypeScript": {
      "language_servers": ["tsgo"],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_other_hints": true,
        "show_type_hints": true,
      },
    },
    "JavaScript": {
      "language_servers": ["tsgo"],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_other_hints": true,
        "show_type_hints": true,
      },
    },
    "JSON": {
      "tab_size": 2,
      "language_servers": ["json-language-server", "..."],
    },
    "Python": {
      "tab_size": 4,
      "show_whitespaces": "all",
      "show_edit_predictions": true,
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
      // ruff format doesn't sort imports; do it via the organize-imports code
      // action on format. Line length etc. come from the project's ruff config.
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
      },
      "language_servers": [
        "pyrefly",
        "ruff",
        "codebook",
        "!pyright",
        "!basedpyright",
        "!ty",
        "!pylsp",
      ],
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": true,
        "show_other_hints": true,
        "show_type_hints": true,
      },
    },
  },

  // ============================================================================
  // Integrated terminal
  // ============================================================================
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font Mono",
    "font_size": 14.0,
    "font_fallbacks": ["JetBrainsMono Nerd Font Mono"],
    "env": {
      "EDITOR": "zed --wait",
    },
    "working_directory": "current_project_directory",
    "button": true,
  },

  // ============================================================================
  // Files: types + scan exclusions
  // ============================================================================
  // Do NOT map the "json" extension to language JSON here — that overrides Zed's
  // built-in JSONC associations and makes json-language-server reject // comments
  // in settings.json ("Comments are not permitted in JSON").
  // https://zed.dev/docs/languages/json
  // https://github.com/zed-industries/zed/issues/14709
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSONC": ["settings.json"],
  },
  "file_scan_exclusions": [
    // Zed defaults
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // Custom
    ".env*",
    "**/out",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/report",
    "**/node_modules",
  ],

  // ============================================================================
  // Privacy
  // ============================================================================
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
